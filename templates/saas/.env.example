# Clerk auth works out of the box in development (keyless mode).
# No Clerk environment variables needed for local dev.
# For production, see DEPLOY.md.

# ─── Client-side (publishable key — safe for browser) ────
# NEXT_PUBLIC_ vars are embedded in the JS bundle at build time.
# They are NOT secrets.

# Centrali API base URL (default for production)
NEXT_PUBLIC_CENTRALI_API_URL=https://centrali.io

# Your workspace slug (find in Console > Settings)
NEXT_PUBLIC_CENTRALI_WORKSPACE=your-workspace-slug

# Publishable key (create in Console > ACCESS > Publishable Keys)
# Format: pk_live_...
NEXT_PUBLIC_CENTRALI_PK=pk_live_your_publishable_key

# ─── Server-side (service account — NEVER expose to browser) ─
# Used in API routes, server components, and server actions only.
# Create in Console > ACCESS > Service Accounts.

CENTRALI_API_URL=https://centrali.io
CENTRALI_WORKSPACE=your-workspace-slug
CENTRALI_CLIENT_ID=ci_your_client_id
CENTRALI_CLIENT_SECRET=sk_your_client_secret
