# ─── Centrali SDK Configuration ──────────────────────────
# All VITE_ variables are embedded in the JS bundle at build time.
# They are NOT secrets — safe for client-side use.

# Centrali API base URL (default for production)
VITE_CENTRALI_API_URL=https://centrali.io

# Your workspace slug (find in Console > Settings)
VITE_CENTRALI_WORKSPACE=your-workspace-slug

# Publishable key (create in Console > ACCESS > Publishable Keys)
# Format: pk_live_...
VITE_CENTRALI_PK=pk_live_your_publishable_key
